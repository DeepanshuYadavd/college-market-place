# create repo on git hub

#  in terminal:

#  config credentials:

#  git init
#  git config --global user.name "name of the git hub"
#  git config --global user.email "name of the email"

#  add remote origin:
# git remote add origin "url of repo"

#  commit and push:
#  git add .
#  git commit -m "message"
#  git push origin master 